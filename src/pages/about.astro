---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const coursework = [
  'Intro to Programming Systems',
  'Intro to Machine Learning',
  'Data Structures & Algorithms',
  'Probability & Stochastic Systems',
  'Intro to Real Analysis',
  'Statistical Genomics (graduate)',
];

const internships = [
  {
    role: 'ML Platform Engineering Intern',
    org: 'Remitly',
    period: 'Jul 2026 – present',
    summary:
      'Building a causal inference model to determine the reasons behind customer churn — not just which customers leave, but why.',
  },
  {
    role: 'SafeConstruct',
    org: 'The Initiative for CryptoCurrencies & Contracts',
    period: 'Jun 2026',
    summary:
      'Built a blockchain-based safety credentialing platform for construction workers — the full story is on the Projects page.',
  },
  {
    role: 'Software Engineering Intern',
    org: 'Nirvana Carbon Solutions',
    period: 'May – Aug 2025',
    summary:
      'Built a Python optimization tool that maps biochar pit and irrigation placement from Google Earth spatial data, and led a team of five mapping 3,000+ hectares of coastal land for mangrove restoration — the largest effort of its kind.',
  },
];

const leadership = [
  {
    role: 'Investor Relations Principal',
    org: 'Princeton Student Ventures',
    period: 'Sep 2024 – present',
    summary:
      'Lead investment theses with SciFi VC, and as a Senior Investments Analyst ran due diligence — market sizing, growth, and retention analysis — to grant up to $10K in funding to Princeton-founded startups. Along the way: conversations with 15+ founders from Princeton and beyond.',
  },
];
---

<BaseLayout
  title="About"
  description={`About ${SITE.name}`}
  background="/roaring20pic.jpg"
  veil={0.32}
>
  <div class="prose">
    <h1>About me</h1>
    <p>
      I'm a computer science student at Princeton University (B.S.E. '28),
      minoring in Quantitative Economics, Computational Biology, and
      Philosophy. My interest in CS has always been broad — I like building
      things, whatever shape they take — but my current focus is machine
      learning: creating models, optimizing them, and shipping the products
      around them. This summer I'm doing exactly that at Remitly, building a
      causal inference model for customer churn.
    </p>
    <h2>Relevant Coursework</h2>
    <ul class="courses">
      {coursework.map((course) => <li>{course}</li>)}
    </ul>

    <h2>Experience</h2>
    <ol class="timeline">
      {
        internships.map((item) => (
          <li>
            <div class="head">
              <span class="title">
                <strong>{item.role}</strong> · {item.org}
              </span>
              <span class="period">{item.period}</span>
            </div>
            <p>{item.summary}</p>
          </li>
        ))
      }
    </ol>

    <h2>Leadership &amp; groups</h2>
    <ol class="timeline">
      {
        leadership.map((item) => (
          <li>
            <div class="head">
              <span class="title">
                <strong>{item.role}</strong> · {item.org}
              </span>
              <span class="period">{item.period}</span>
            </div>
            <p>{item.summary}</p>
          </li>
        ))
      }
    </ol>

  </div>
</BaseLayout>

<style>
  .prose {
    font-size: 0.95rem;
    color: #000;
    font-weight: 500;
    /* A soft radial "scrim": strongest right behind the text, feathering
       out to fully transparent at the edges — no box, no borders, so the
       photo stays visible everywhere while the text reads clearly */
    background: radial-gradient(
      110% 105% at 50% 45%,
      rgba(255, 255, 255, 0.78) 50%,
      rgba(255, 255, 255, 0.4) 78%,
      rgba(255, 255, 255, 0) 100%
    );
    padding: 2rem 2.75rem 2.5rem;
    text-shadow:
      0 1px 3px rgba(255, 255, 255, 0.95),
      0 0 14px rgba(255, 255, 255, 0.85);
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 1rem;
  }

  h2 {
    font-size: 1.3rem;
    margin: 2.5rem 0 1rem;
  }

  .courses {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
  }

  .courses li {
    font-size: 0.8rem; /* course pills keep their original look */
    font-weight: 400;
    font-family: var(--font-mono);
    background: var(--color-surface);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    color: var(--color-text-muted);
  }

  .timeline {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    border-left: 2px solid var(--color-border);
  }

  .timeline li {
    position: relative;
    padding: 0 0 1.5rem 1.25rem;
  }

  .timeline li:last-child {
    padding-bottom: 0.25rem;
  }

  .timeline li::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 0.5rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }

  .period {
    color: #000;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .timeline p {
    margin: 0.25rem 0 0;
    color: #000;
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .prose {
      padding: 1.5rem 1.1rem 2rem;
    }

    h1 {
      font-size: 1.7rem;
    }
  }
</style>

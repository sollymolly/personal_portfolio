---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, summary, tech, date, github, demo } = project.data;
const { Content } = await render(project);

const when = date.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout title={title} description={summary}>
  <article class="prose">
    <p class="back"><a href="/projects">← All projects</a></p>
    <h1>{title}</h1>
    <p class="summary">{summary}</p>
    <div class="meta">
      <ul class="tech">
        {tech.map((t) => <li>{t}</li>)}
      </ul>
      <span class="date">{when}</span>
    </div>
    {
      (github || demo) && (
        <p class="ext">
          {github && (
            <a href={github} target="_blank" rel="noopener">
              View the code →
            </a>
          )}
          {demo && (
            <a href={demo} target="_blank" rel="noopener">
              Live demo →
            </a>
          )}
        </p>
      )
    }
    <hr />
    <Content />
  </article>
</BaseLayout>

<style>
  .back {
    margin: 0 0 2rem;
    font-size: 0.9rem;
  }

  h1 {
    font-size: 2.1rem;
    margin: 0 0 0.5rem;
  }

  .summary {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
  }

  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tech li {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    background: var(--color-surface);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    color: var(--color-text-muted);
  }

  .date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .ext {
    display: flex;
    gap: 1.5rem;
    margin: 1rem 0 0;
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.75rem 0;
  }
</style>

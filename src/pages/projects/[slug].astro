---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, summary, tech, date, github, demo, slides } = project.data;
const { Content } = await render(project);

const projectUrl = demo ?? github;

const when = date.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout
  title={title}
  description={summary}
  background={project.data.background}
  veil={0.32}
>
  <article class="prose">
    <p class="back"><a href="/projects">← All projects</a></p>
    <h1>{title}</h1>
    <p class="summary">{summary}</p>
    <div class="meta">
      <ul class="tech">
        {tech.map((t) => <li>{t}</li>)}
      </ul>
      <span class="date">{when}</span>
    </div>
    {
      (projectUrl || slides) && (
        <p class="ext">
          {projectUrl && (
            <a class="btn" href={projectUrl} target="_blank" rel="noopener">
              View project →
            </a>
          )}
          {slides && (
            <a
              class="btn btn-secondary"
              href={slides}
              target="_blank"
              rel="noopener"
            >
              View slides →
            </a>
          )}
        </p>
      )
    }
    <hr />
    <Content />
  </article>
</BaseLayout>

<style>
  .prose {
    /* Same treatment as the About page: strong photo, with a feathered
       radial scrim and text halo keeping the article readable */
    color: #000;
    font-weight: 500;
    background: radial-gradient(
      110% 105% at 50% 45%,
      rgba(255, 255, 255, 0.78) 50%,
      rgba(255, 255, 255, 0.4) 78%,
      rgba(255, 255, 255, 0) 100%
    );
    padding: 2rem 2.75rem 2.5rem;
    text-shadow:
      0 1px 3px rgba(255, 255, 255, 0.95),
      0 0 14px rgba(255, 255, 255, 0.85);
  }

  .back {
    margin: 0 0 2rem;
    font-size: 0.9rem;
  }

  h1 {
    font-size: 2.1rem;
    margin: 0 0 0.5rem;
  }

  .summary {
    font-size: 1.15rem;
    color: #000;
    margin: 0 0 1rem;
  }

  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .tech li {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    background: var(--color-surface);
    border-radius: 999px;
    padding: 0.15rem 0.6rem;
    color: var(--color-text-muted);
  }

  .date {
    font-size: 0.85rem;
    color: #000;
  }

  .ext {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.5rem 0 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.4rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    text-shadow: none;
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.3);
    transition:
      background 0.15s ease,
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }

  .btn:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(37, 99, 235, 0.38);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.9);
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
    padding: calc(0.7rem - 2px) calc(1.4rem - 2px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
  }

  .btn-secondary:hover {
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 6px 18px rgba(37, 99, 235, 0.3);
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.75rem 0;
  }

  @media (max-width: 640px) {
    .prose {
      padding: 1.5rem 1.1rem 2rem;
    }

    h1 {
      font-size: 1.7rem;
    }

    .summary {
      font-size: 1.05rem;
    }
  }
</style>

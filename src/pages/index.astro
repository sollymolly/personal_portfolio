---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE } from '../config';

const featured = (await getCollection('projects', ({ data }) => data.featured))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout title={`${SITE.name} — ${SITE.role}`} background="/nassau_hall.jpg">
  <section class="hero-wrap">
    <div class="container">
      <div class="glass">
        <img
          class="portrait"
          src="/solpark_profile.jpeg"
          alt={`Portrait of ${SITE.name}`}
          width="190"
          height="190"
          loading="eager"
        />
        <h1>Sol Park</h1>
        <p class="role">{SITE.role}</p>
        <p class="tagline">{SITE.tagline}</p>
      </div>
    </div>
  </section>

  <section class="featured container">
    <h2>Featured projects</h2>
    <div class="grid">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="links">
      <a class="btn github" href={SITE.github} target="_blank" rel="noopener">
        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        GitHub
      </a>
      <a class="btn linkedin" href={SITE.linkedin} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path
            d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"
          ></path>
        </svg>
        LinkedIn
      </a>
      <a class="btn resume" href="/resume">Resume</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-wrap {
    /* The Nassau Hall photo now covers the whole page (see BaseLayout) */
    padding-block: 0.5rem 0;
  }

  .glass {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 46rem;
    margin-inline: auto;
    padding: 2.5rem 2.5rem 2.25rem;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.75);
    border-radius: 20px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.14);
  }

  .portrait {
    width: 190px;
    height: 190px;
    object-fit: cover;
    border-radius: 50%;
    border: 4px solid #ffffff;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 3.1rem);
    margin: 0 0 0.5rem;
  }

  .role {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }

  .tagline {
    max-width: 38rem;
    margin: 0;
    color: var(--color-text-muted);
  }

  .featured {
    margin-top: 2.5rem;
    text-align: center;
  }

  h2 {
    font-size: 1.4rem;
    margin: 0 0 1.25rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 19rem));
    justify-content: center;
    gap: 1.25rem;
    text-align: left;
  }

  .links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1.5rem;
    border-radius: 999px;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      background-color 0.15s ease;
  }

  .btn:hover {
    color: #ffffff;
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.2);
  }

  .btn.github {
    background: #24292f;
  }

  .btn.github:hover {
    background: #3a4046;
  }

  .btn.linkedin {
    background: #0a66c2;
  }

  .btn.linkedin:hover {
    background: #0b74de;
  }

  .btn.resume {
    background: #4285f4;
  }

  .btn.resume:hover {
    background: #5a95f5;
  }

  @media (max-width: 640px) {
    .glass {
      padding: 1.75rem 1.25rem 1.5rem;
    }

    .portrait {
      width: 150px;
      height: 150px;
    }

    .role {
      font-size: 1.15rem;
    }

    .links {
      gap: 0.75rem;
    }

    .btn {
      padding: 0.6rem 1.2rem;
      font-size: 0.95rem;
    }
  }
</style>
